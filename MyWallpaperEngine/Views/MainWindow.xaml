<Window x:Class="MyWallpaperEngine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:MyWallpaperEngine.ViewModels"
        xmlns:conv="clr-namespace:MyWallpaperEngine.Converters"
        mc:Ignorable="d"
        Title="MyWallpaperEngine - Pro Build" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Conversor das Imagens -->
    <Window.Resources>
        <conv:ImagePathConverter x:Key="ImageConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- REGIAO 1: SIDEBAR -->
        <Border Grid.Column="0" Background="{DynamicResource MaterialDesignDarkBackground}" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
                    <materialDesign:PackIcon Kind="MonitorDashboard" Width="32" Height="32" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="MyWallpaper" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Grid.Row="1" Content="📂 Importar Pasta" 
                        Command="{Binding SelecionarPastaCommand}" 
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="#28A745" BorderBrush="#28A745" Foreground="White" Height="45"
                        Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="8"/>

                <!-- Botão de teste, erro forçado -->
                <Button Grid.Row="2" Content="💥 Testar Airbag"
                        Command="{Binding SimularErroCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#E53935" BorderBrush="#E53935"
                        VerticalAlignment="Bottom" Margin="0,0,0,20"
                        Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="8"
                        ToolTip="Gera um erro fatal para testar o tratamento global de exceções"/>

                <!-- Controles do Modo Shuffle -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Opções de Shuffle" FontWeight="Bold" Margin="0,0,0,15" Foreground="#AAA"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Trocar a cada:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding OpcoesTempo}" SelectedItem="{Binding TempoSelecionado}" Width="60"/>
                        <TextBlock Text="min" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <Button Content="{Binding TextoBotaoTimer}" 
                            Command="{Binding ToggleTimerCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="{DynamicResource PrimaryHueMidBrush}" BorderBrush="{DynamicResource PrimaryHueMidBrush}" 
                            Foreground="White" Height="45" Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- REGIAO 2: MAIN AREA -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Sua Galeria" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,5,0,0"/>
            </StackPanel>

            <ListBox Grid.Row="1" ItemsSource="{Binding Wallpapers}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Width="220" Margin="10" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp3" Background="{DynamicResource MaterialDesignDarkBackground}">
                            <StackPanel>

                                
                                <Border Height="130" ClipToBounds="True">
                                    <Image Source="{Binding CaminhoCompleto, Converter={StaticResource ImageConverter}, IsAsync=True}" Stretch="UniformToFill" />
                                </Border>

                                <TextBlock Text="{Binding NomeExibicao}" FontWeight="SemiBold" Margin="10,12,10,5" TextTrimming="CharacterEllipsis" ToolTip="{Binding CaminhoCompleto}"/>

                                <Grid Margin="10,0,10,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="Definir Fundo" 
                                            Command="{Binding DataContext.AplicarWallpaperCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}" 
                                            Margin="0,0,5,0" 
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            ToolTip="Aplicar este papel de parede agora"
                                            Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="6"/>

                                    <Button Grid.Column="1" 
                                            Command="{Binding DataContext.DeletarWallpaperCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#E53935" BorderBrush="#E53935" Padding="8,0"
                                            ToolTip="Excluir imagem da galeria"
                                            Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="6">
                                        <materialDesign:PackIcon Kind="DeleteOutline" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>