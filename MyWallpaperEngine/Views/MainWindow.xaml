<Window x:Class="MyWallpaperEngine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:MyWallpaperEngine.ViewModels"
        xmlns:conv="clr-namespace:MyWallpaperEngine.Converters"
        mc:Ignorable="d"
        Title="MyWallpaperEngine" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        
        TextElement.Foreground="#EAEAEA"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:ImagePathConverter x:Key="ImageConverter" />
    </Window.Resources>

    <!-- Fundo principal unificado. Cinza muito escuro e fosco, quase preto. -->
    <Border Background="#121212" CornerRadius="10" BorderBrush="#282828" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Barra de Título super limpa -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Sidebar um pouco mais fina para dar ênfase na Galeria -->
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================== -->
            <!-- REGIAO 1: BARRA DE TÍTULO INVISÍVEL        -->
            <!-- ========================================== -->
            <!-- Background Transparente para mesclar com o app inteiro -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Os botões da janela são super discretos agora -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                        <Button Click="BtnMinimize_Click" Width="30" Height="30" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                            <materialDesign:PackIcon Kind="Minus" Foreground="#888888" Width="18" Height="18"/>
                        </Button>
                        <Button Click="BtnClose_Click" Width="30" Height="30" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" Margin="5,0,0,0">
                            <materialDesign:PackIcon Kind="Close" Foreground="#888888" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!-- REGIAO 2: SIDEBAR MINIMALISTA              -->
            <!-- ========================================== -->
            <!-- Sem cor de fundo diferente. Apenas uma linha sutil dividindo as áreas -->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#222222" BorderThickness="0,0,1,0">
                <Grid Margin="25,0,25,25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40">
                        <!-- 👇 CORREÇÃO: Removido o LetterSpacing teimoso -->
                        <TextBlock Text="MyWallpaper" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                        <TextBlock Text="Engine" FontSize="12" FontWeight="Regular" Foreground="#777777"/>
                    </StackPanel>

                    <!-- Botão de Ação Primária: Estilo "High Contrast" (Fundo Branco, Letra Preta) -->
                    <Button Grid.Row="1" Command="{Binding SelecionarPastaCommand}" 
                            Height="42" Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="6" BorderThickness="0" Background="#EDEDED" Foreground="#121212">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Importar" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2" Content="Testar Crash" Command="{Binding SimularErroCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555555"
                            VerticalAlignment="Bottom" Margin="0,0,0,20" Cursor="Hand" FontSize="11"/>

                    <!-- Controle de Timer limpo, sem caixas em volta -->
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="Piloto Automático" FontWeight="SemiBold" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Trocar a cada" VerticalAlignment="Center" Foreground="#777777" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding OpcoesTempo}" SelectedItem="{Binding TempoSelecionado}" Width="50" Foreground="#EAEAEA" BorderBrush="#333333" Margin="10,0,0,0" Padding="4,2"/>
                            <TextBlock Text="min" VerticalAlignment="Center" Foreground="#777777" FontSize="12" Margin="5,0,0,0"/>
                        </StackPanel>

                        <!-- Botão Secundário: Sem fundo, apenas borda sutil -->
                        <Button Content="{Binding TextoBotaoTimer}" Command="{Binding ToggleTimerCommand}" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                Foreground="#CCCCCC" BorderBrush="#333333" Height="38" Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="6" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!-- REGIAO 3: MAIN AREA (GALERIA)              -->
            <!-- ========================================== -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="30,0,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="Galeria" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding Wallpapers}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Card Flat: Sem sombra pesada (Elevation 0), apenas borda e fundo levemente mais claro -->
                            <materialDesign:Card Width="220" Margin="0,0,20,20" UniformCornerRadius="8" Background="#1A1A1A" BorderBrush="#252525" BorderThickness="1" materialDesign:ElevationAssist.Elevation="Dp0">
                                <StackPanel>
                                    <Border Height="125" ClipToBounds="True" CornerRadius="7,7,0,0">
                                        <Image Source="{Binding CaminhoCompleto, Converter={StaticResource ImageConverter}, IsAsync=True}" Stretch="UniformToFill" />
                                    </Border>

                                    <TextBlock Text="{Binding NomeExibicao}" FontWeight="Medium" FontSize="12" Foreground="#D0D0D0" Margin="12,12,12,8" TextTrimming="CharacterEllipsis" ToolTip="{Binding CaminhoCompleto}"/>

                                    <Grid Margin="12,0,12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Botões de ação dos cards agora são discretos -->
                                        <Button Grid.Column="0" Content="Aplicar Fundo" 
                                                Command="{Binding DataContext.AplicarWallpaperCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                CommandParameter="{Binding}" 
                                                Margin="0,0,8,0" Height="28" FontSize="11"
                                                Style="{StaticResource MaterialDesignFlatButton}" Background="#252525" Foreground="#EAEAEA"
                                                Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="4" Padding="0"/>

                                        <Button Grid.Column="1" Width="28" Height="28" Padding="0"
                                                Command="{Binding DataContext.DeletarWallpaperCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#888888"
                                                Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="4" ToolTip="Remover">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>